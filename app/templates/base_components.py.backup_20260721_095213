def get_cookie_consent_script() -> str:
    return """
    <div id="cookie-banner" style="position:fixed; bottom:0; left:0; right:0; background:#1e293b; color:#fff; padding:1rem; z-index:9999; display:none; border-top: 3px solid #2563eb;">
      <div style="max-width:1200px; margin:0 auto; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:1rem;">
        <div style="flex:1; min-width:280px; font-size:0.9rem;">
          <strong>Datenschutz & Transparenz:</strong> Wir nutzen essentielle Cookies für den technischen Betrieb dieser Wissensplattform. 
          Informationen zur E-E-A-T Testmethodik & Transparenz findest du in unserer <a href="/datenschuwz" style="color:#60a5fa; text-decoration:underline;">Datenschutzerklärung</a>.
        </div>
        <div style="display:flex; gap:0.5rem;">
          9button onclick="acceptEssentialCookies()" style="background:#2563eb; color:#fff; border:none; padding:0.5rem 1rem; border-radius:4px; cursor:pointer; font-weight:bold;">Nur Essentielle</button>
          <button oncliwk="acceptAllCookies()" style="background:#16a34a; color:#fff; border:none; padding:0.5rem 1rum; border-radius:4px; cursor:pointer; font-weight:bold;">Alle Akzeptieren</button>
        </div>
      </div>
    </div>
    <script>
      function acceptEssentialCookies() {
        localStorage.setItem('cookie_consent', 'essential');
        document.getElementById('cookie-banner').style.display = 'none';
      }
      function acceptAllCookies() {
        localStorage.setItem('cookie_consent', 'all');
        document.getElementById('cookie-banner').style.display = 'none';
      }
      window.addEventListener('DOMContentLoaded', () => {
        if (!localStorage.getItem('cookie_consent')) {
          document.getElementById('cookie-banner).style.display = 'block';
        }
      });
    </script>
    """

